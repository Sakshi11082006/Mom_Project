@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register | MOM System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- YOUR register CSS -->
    <link href="~/assets/css/registerStyle.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-wrapper">
        <div class="auth-card">

            <!-- Header -->
            <div class="text-center mb-4">
                <div class="logo-icon">
                    <i class="bi bi-person-plus"></i>
                </div>
                <h6 class="brand-name">Join MOM System</h6>
                <h4 class="fw-bold">Create Account</h4>
                <p class="text-muted small">
                    Join the meeting management system to organize and track meetings efficiently
                </p>
            </div>

            <!-- Form -->
            <form>
                <div class="row g-3">

                    <div class="col-md-6 position-relative">
                        <label class="form-label small">Username</label>
                        <input type="text" class="form-control custom-input" placeholder="Username">
                        <i class="bi bi-person input-icon"></i>
                        <small class="text-muted">3–50 characters required</small>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label class="form-label small">Role</label>
                        <select class="form-select custom-input">
                            <option selected>------ Select Role ------</option>
                            <option>Admin</option>
                            <option>Staff</option>
                            <option>User</option>
                        </select>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label class="form-label small">Password</label>
                        <input type="password" class="form-control custom-input" placeholder="Password">
                        <i class="bi bi-lock input-icon"></i>
                        <small class="text-muted">Minimum 6 characters</small>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label class="form-label small">Confirm Password</label>
                        <input type="password" class="form-control custom-input" placeholder="Confirm Password">
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>

                    <div class="col-12 position-relative">
                        <label class="form-label small">Staff Member (Optional)</label>
                        <select class="form-select custom-input">
                            <option selected>Link Staff Member</option>
                            <option>Staff 1</option>
                            <option>Staff 2</option>
                        </select>
                        <small class="text-muted">Link to a staff member for better tracking</small>
                    </div>
                </div>

                <button asp-controller="Dashboard" asp-action="DashboardPage" class="btn btn-auth w-100 mt-4">
                    <i class="bi bi-person-check me-1"></i> Create Account
                </button>

                <p class="text-center small mt-3 mb-0">
                    Already have an account?
                    <a href="login.html" class="fw-semibold text-decoration-none">Sign in here</a>
                </p>
            </form>

        </div>
    </div>

</body>
</html>