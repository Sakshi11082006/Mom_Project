@model Mom_Project.Models.StaffModel
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Add New Staff Member</h1>
    <p class="text-muted">Register a new staff member</p>

    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item active"></li>
        </ol>
    </nav>
</div>
<!-- End Page Title -->
<section class="section">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card border-0 shadow-lg rounded-4">

                <!-- Card Header -->
                <div class="card-header text-white rounded-top-4"
                     style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <h5 class="mb-0">
                        <i class="bi bi-person-plus me-2"></i>
                        Add New Staff Member
                    </h5>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">

                    <form asp-controller="Staff" asp-action="Save" method="post">

                        <input type="hidden" asp-for="StaffID"/>
                        <!-- Row 1 -->
                        <div class="row mb-4">

                            <div class="col-md-6">
                                <label asp-for="StaffName" class="form-label fw-semibold">Staff Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    <input asp-for="StaffName" type="text" class="form-control" placeholder="Enter staff name">
                                    <span class="input-group-text bg-white border-start-0 text-success">
                                        <i class="bi bi-check-lg"></i>
                                    </span>
                                </div>
                               <span asp-validation-for="StaffName" class="text-danger fw-bold"></span><br />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Department</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-building"></i>
                                    </span>
                                    <select asp-for="DepartmentID" asp-items="ViewBag.DepartmentList"
                                        class="form-select border-primary">
                                        <option value="" selected disabled>-- Select Department --</option>
                                    </select>
                                </div>
                            </div>

                        </div>

                        <!-- Row 2 -->
                        <div class="row mb-4">

                            <div class="col-md-6">
                                <label asp-for="EmailAddress" class="form-label fw-semibold">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="EmailAddress" type="email" class="form-control" placeholder="Enter email address">
                                </div>
                                <span asp-validation-for="EmailAddress" class="text-danger fw-bold"></span><br />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MobileNo" class="form-label fw-semibold">Mobile Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-phone"></i>
                                    </span>
                                    <input asp-for="MobileNo" type="text" class="form-control" placeholder="Enter mobile number">
                                </div>
                                <span asp-validation-for="MobileNo" class="text-danger fw-bold"></span><br />
                                <small class="text-muted">
                                    Example: +91 98765 43210
                                </small>
                            </div>


                        </div>

                        <!-- Remarks -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Remarks</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light align-items-start">
                                    <i class="bi bi-chat-left-text"></i>
                                </span>
                                <textarea class="form-control" rows="4" placeholder="Enter any additional remarks (optional)"></textarea>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Staff" asp-action="StaffList"
                               class="btn btn-outline-secondary">
                                ← Back to List
                            </a>

                            <button type="submit"
                                    class="btn px-4 text-white"
                                    style="background: linear-gradient(135deg, #667eea, #764ba2); border:none;">
                                <i class="bi bi-check-circle me-1"></i>
                                Create Staff Member
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</section>
