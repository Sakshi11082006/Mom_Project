@model List<MeetingVenueModel>
<div class="pagetitle">
    <h1>Meeting Venue List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="MeetingVenue" asp-action="MeetingVenueList">Home</a></li>
            <li class="breadcrumb-item active">MeetingVenue List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Error Message -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <!-- Left Side Title -->
                        <h5 class="card-title mb-0">
                            <i class="bi bi-building me-2"></i>Meeting Venue List
                        </h5>

                        <!-- Right Side Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a href="@Url.Action("MeetingVenueAddEdit", "MeetingVenue")"
                               class="btn btn-primary">
                                <i class="bi bi-plus-lg"></i> Add MeetingVenue
                            </a>

                            <a asp-controller="MeetingVenue" asp-action="ExportToExcel"
                               class="btn btn-success">
                                Export Meeting Venue Data to Excel
                            </a>
                        </div>
                    </div>

                    <!-- search -->

                    <form method="post" asp-action="MeetingVenueList" asp-controller="MeetingVenue" class="mb-3">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label for="SearchText" class="form-label">Search Meeting Venue</label>
                                <input type="text" name="SearchText" id="SearchText" class="form-control"
                                       placeholder="Enter Meeting Venue name" value="@ViewBag.SearchText" />
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-info">
                                    <i class="fas fa-search"></i> Search
                                </button>
                                <a asp-action="MeetingVenueList" asp-controller="MeetingVenue" class="btn btn-secondary ms-2">
                                    <i class="fas fa-undo"></i> Reset
                                </a>
                            </div>
                        </div>
                    </form>

                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
                        <table class="table ">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>MeetingVenue Name </th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var meetingVenue in Model)
                                {
                                    <tr>
                                        <td>@meetingVenue.MeetingVenueID</td>
                                        <td>@meetingVenue.MeetingVenueName</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-action="MeetingVenueAddEdit" asp-route-id="@meetingVenue.MeetingVenueID"
                                               title="Edit"
                                               style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #0d6efd;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#0d6efd;
                                                       text-decoration:none;
                                                    ">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="Delete" asp-route-id="@meetingVenue.MeetingVenueID"
                                               title="Delete"
                                               style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #dc3545;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#dc3545;
                                                       text-decoration:none;
                                                    ">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </td>

                                    </tr>

                                }
                            </tbody>
                        </table>
                    }
                    <!-- End Table with stripped rows -->

                </div>
            </div>

        </div>
    </div>
</section>