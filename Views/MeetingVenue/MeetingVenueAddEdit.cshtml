@model Mom_Project.Models.MeetingVenueModel
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Add New Meeting Venue</h1>
    <p class="text-muted">Create a new meeting venue</p>

    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item active"></li>
        </ol>
    </nav>
</div>
<!-- End Page Title -->
<section class="section">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card border-0 shadow-lg rounded-4">

                <!-- Card Header -->
                <div class="card-header text-white rounded-top-4"
                     style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <h5 class="mb-0">
                        <i class="bi bi-tag me-2"></i>
                        Add New Meeting Type
                    </h5>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">

                    <form asp-controller="MeetingVenue" asp-action="Save" method="post">

                        <input type="hidden" asp-for="MeetingVenueID" />

                        <!-- Meeting Type -->
                        <div class="mb-4">
                            <label asp-for="MeetingVenueName" class="form-label fw-semibold">Venue Name</label>

                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-tag"></i>
                                </span>
                                <input asp-for="MeetingVenueName" type="text" class="form-control" placeholder="Enter meeting venue name">
                                <span class="input-group-text bg-white border-start-0 text-success">
                                    <i class="bi bi-check-lg"></i>
                                </span>
                            </div>
                            <span asp-validation-for="MeetingVenueName" class="text-danger fw-bold"></span><br />

                            <small class="text-muted">
                                e.g., Conference Room A, Board Room, Virtual (Zoom), Auditorium
                            </small>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="MeetingVenue" asp-action="MeetingVenueList"
                               class="btn btn-outline-secondary">
                                ← Back to List
                            </a>

                            <button type="submit"
                                    class="btn px-4 text-white"
                                    style="background: linear-gradient(135deg, #667eea, #764ba2); border:none;">
                                <i class="bi bi-check-circle me-1"></i>
                                Create Meeting Type
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</section>