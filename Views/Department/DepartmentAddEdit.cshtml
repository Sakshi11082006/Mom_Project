@model Mom_Project.Models.DepartmentModel
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Edit Department</h1>
    <p class="text-muted">Update existing department</p>

    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item active"></li>
        </ol>
    </nav>
</div>
<!-- End Page Title -->

<section class="section">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="card border-0 shadow-lg rounded-4">

                <!-- Card Header -->
                <div class="card-header text-white rounded-top-4"
                     style="background: linear-gradient(90deg, #5f6ae1, #7b4ca0);">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-building me-2"></i>
                        Edit Department
                    </h5>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">

                    <form asp-controller="Department" asp-action="Save" method="post" enctype="multipart/form-data">

                        <input type="hidden" asp-for="DepartmentID" />

                        <!-- Department Name -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold" asp-for="DepartmentName">Department Name</label>

                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-building"></i>
                                </span>
                                <input asp-for="DepartmentName" type="text" class="form-control border-primary" placeholder="Enter department name"/>
                            </div>
                            <span asp-validation-for="DepartmentName" class="text-danger fw-bold"></span><br />

                            <small class="text-muted">
                                e.g., Human Resources, Information Technology, Finance
                            </small>
                        </div>

                        <!-- Department Logo Upload -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Department Logo</label>

                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-image"></i>
                                </span>

                                <input asp-for="LogoFile" type="file"
                                       class="form-control border-primary" />
                            </div>

                            <small class="text-muted">
                                Upload department logo (PNG, JPG)
                            </small>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-controller="Department" asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                ← Back to List
                            </a>

                            <button type="submit" class="btn text-white px-4" style="background: linear-gradient(90deg, #5f6ae1, #7b4ca0); border:none;">
                                <i class="bi bi-check-circle me-1"></i>
                                Update Department
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
