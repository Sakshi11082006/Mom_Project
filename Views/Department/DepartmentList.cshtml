@model List<DepartmentModel>
<div class="pagetitle">
    <h1>Department List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Department" asp-action="DepartmentList">Home</a></li>
            <li class="breadcrumb-item active">Department List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Error Message -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0"><i class="bi bi-building me-2"></i>Department List</h5>

                        <a href="@Url.Action("DepartmentAddEdit", "Department")"
                           class="btn btn-primary">
                            <i class="bi bi-plus-lg"></i> Add Department
                        </a>
                    </div>

                    <form method="post" asp-action="Index" asp-controller="Department" class="mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label for="SearchText" class="form-label">Search by Department Name</label>
                            <input type="text" name="SearchText" id="SearchText" class="form-control"
                                   placeholder="Enter department name" value="@ViewBag.SearchText" />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-info">
                                <i class="fas fa-search"></i> Search
                            </button>
                                <a asp-controller="Department" asp-action="Index" class="btn btn-secondary ms-2">
                                <i class="fas fa-undo"></i> Reset
                            </a>
                        </div>
                    </div>
                    </form>

                    @if (Model != null && Model.Count > 0)
                    {
                        <table class="table">
                            <thead>
                                <tr>

                                    <th>#</th>
                                    <th>Department Name </th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var department in Model)
                                {
                                    <tr>
                                        <td>@department.DepartmentID</td>
                                        <td>@department.DepartmentName</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a href="@Url.Action("DepartmentAddEdit", "Department", new { id = department.DepartmentID })"
                                               title="Edit"
                                               style=" width:36px;
                                                               height:36px;
                                                               border:1.5px solid #0d6efd;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#0d6efd;
                                                               text-decoration:none;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="DeleteDepartment" asp-controller="Department" asp-route-id="@department.DepartmentID"
                                               title="Delete"
                                               style=" width:36px;
                                                               height:36px;
                                                               border:1.5px solid #dc3545;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#dc3545;
                                                               text-decoration:none;">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No departments found. Click "Add New Department" to create one.
                        </div>
                    }


                </div>
            </div>

        </div>
    </div>
</section>
