@model List<MeetingMemberModel>
<div class="pagetitle">
    <h1>Meeting Members</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="MeetingMember" asp-action="MeetingMemberList">Home</a></li>
            <li class="breadcrumb-item active">Meeting Member List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-people-fill"></i>
                            Meeting Member List
                        </h5>

                        <a href="@Url.Action("MeetingMemberAddEdit","MeetingMember")"
                           class="btn btn-primary">
                            <i class="bi bi-plus-lg"></i> Add Members
                        </a>
                    </div>


                    <!-- Table with stripped rows -->
                    @if(Model != null && Model.Count > 0)
                    {
                        <table class="table datatable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Present</th>
                                    <th>Remarks</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var MeetingMember in Model)
                                {
                                    <tr>
                                        <td>@MeetingMember.MeetingMemberID</td>
                                        <td>@MeetingMember.IsPresent</td>
                                        <td>@MeetingMember.Remarks</td>
                                        <td class="d-flex gap-2 align-items-center">
                                            <!-- Edit Button -->

                                            <a href="@Url.Action("MeetingMemberAddEdit", "MeetingMember", new{ id = MeetingMember.MeetingMemberID})"
                                                title="Edit"
                                                style=" width:36px;
                                                        height:36px;
                                                        border:1.5px solid #0d6efd;
                                                        border-radius:6px;
                                                        display:flex;
                                                        align-items:center;
                                                        justify-content:center;
                                                        color:#0d6efd;
                                                        text-decoration:none;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->

                                            <a href="@Url.Action("Delete", "MeetingMember", new { id = MeetingMember.MeetingMemberID })"
                                               title="Delete"
                                               style=" width:36px;
                                                       height:36px;
                                                       border:1.5px solid #dc3545;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#dc3545;
                                                       text-decoration:none;">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No departments found. Click "Add New Department" to create one.
                        </div>
                    }


                    <!-- ✅ SCRIPT MUST BE WRITTEN ONLY ONCE -->
                    <script>
                        function toggleAttendance(btn) {
                            if (btn.innerText === "Present") {
                                btn.innerText = "Absent";
                                btn.classList.remove("btn-success");
                                btn.classList.add("btn-danger");
                            } else {
                                btn.innerText = "Present";
                                btn.classList.remove("btn-danger");
                                btn.classList.add("btn-success");
                            }
                        }
                    </script>

                    <!-- End Table with stripped rows -->

                </div>
            </div>

        </div>
    </div>
</section>