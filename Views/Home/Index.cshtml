@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | MOM System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- YOUR LOGIN CSS -->
    <link href="~/assets/css/loginStyle.css" rel="stylesheet" />


</head>
<body>

    <div class="login-wrapper">
        <div class="login-card">

            <!-- Header -->
            <div class="text-center mb-4">
                <div class="logo-icon">
                    <i class="bi bi-check2-square"></i>
                </div>
                <h6 class="brand-name">MOM System</h6>
                <h4 class="fw-bold">Welcome Back</h4>
                <p class="text-muted small">
                    Sign in to access your meeting management dashboard
                </p>
            </div>

            <!-- Form -->
            <form>
                <div class="mb-3 position-relative">
                    <label class="form-label small">Username</label>
                    <input type="text" class="form-control custom-input" placeholder="Enter username">
                    <i class="bi bi-person input-icon"></i>
                </div>

                <div class="mb-3 position-relative">
                    <label class="form-label small">Password</label>
                    <input type="password" class="form-control custom-input" placeholder="Enter password">
                    <i class="bi bi-lock input-icon"></i>
                    <i class="bi bi-eye password-toggle"></i>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox">
                        <label class="form-check-label small">Remember me</label>
                    </div>
                    <a href="#" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button asp-controller="Dashboard" asp-action="DashboardPage" class="btn btn-login w-100 mb-3">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                </button>

                <p class="text-center small mb-0">
                    Don’t have an account?
                    <a asp-controller="Login" asp-action="RegisterPage" class="fw-semibold text-decoration-none">Create an account</a>
                </p>
            </form>
        </div>
    </div>

</body>
</html>