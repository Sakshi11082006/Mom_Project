        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-4 p-3">
            <small class="text-warning fw-semibold">ATTENDANCE RATE</small>
            <h4 class="fw-bold mt-2">33.3%</h4>
        </div>
    </div>

    <div class="col-md-3">
