@model List<MeetingTypeModel>
<div class="pagetitle">
    <h1>MeetingType List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="MeetingType" asp-action="MeetingTypeList">Home</a></li>
            <li class="breadcrumb-item active">MeetingType List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->
<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Error Message -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0"><i class="bi bi-building me-2"></i>MeetingType List</h5>

                        <a href="@Url.Action("MeetingTypeAddEdit", "MeetingType")" class="btn btn-primary">
                            <i class="bi bi-plus-lg"></i> Add new MeetingType
                        </a>
                    </div>



                    <!-- Table with stripped rows -->
                    @if(Model != null && Model.Count > 0)
                    {
                        <table class="table datatable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>MeetingType Name </th>
                                    <th>Remarks </th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var MeetingType in Model)
                                {
                                    <tr>
                                        <td>@MeetingType.MeetingTypeID</td>
                                        <td>@MeetingType.MeetingTypeName</td>
                                        <td>@MeetingType.Remarks</td>
                                        <td class="d-flex gap-2 align-items-center">
                                            <!-- Edit Button -->
                                            <a href="@Url.Action("MeetingTypeAddEdit", "MeetingType", new { id = MeetingType.MeetingTypeID })"
                                               title="Edit"
                                               style=" width:36px;
                                                               height:36px;
                                                               border:1.5px solid #0d6efd;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#0d6efd;
                                                               text-decoration:none;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a href="@Url.Action("Delete", "MeetingType", new { id = MeetingType.MeetingTypeID })"
                                               title="Delete"
                                               style=" width:36px;
                                                               height:36px;
                                                               border:1.5px solid #dc3545;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#dc3545;
                                                               text-decoration:none;">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            No departments found. Click "Add New Department" to create one.
                        </div>
                    }

                    <!-- End Table with stripped rows -->

                </div>
            </div>

        </div>
    </div>
</section>