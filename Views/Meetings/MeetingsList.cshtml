@model List<MeetingsModel>
<div class="pagetitle">
    <h1>Meetings List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Meetings" asp-action="MeetingsList">Home</a></li>
            <li class="breadcrumb-item active">Meetings List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Error Message *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <a class="btn text-white mb-3" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                <i class="bi bi-plus-circle"></i> Schedule Meeting
            </a>

            <a class="btn btn-success mb-3">
                <i class="bi bi-file-earmark-excel"></i> Export
            </a>


            <div class="card border-0 shadow-lg rounded-4 mb-4">
                <div class="card-header text-white rounded-top-4"
                     style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <h6 class="mb-0">
                        <i class="bi bi-funnel me-2"></i> Search & Filters
                    </h6>
                </div>

                <div class="card-body p-4">
                    <div class="row align-items-end">
                        <div class="row mb-3">

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Meeting Type</label>
                                <div class="input-group">
                                    <select class="form-select">
                                        <option selected value="">All Types</option>
                                        
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Department</label>
                                <div class="input-group">
                                    <select class="form-select">
                                        <option selected value="">All Departments</option>
                                        
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Venue</label>
                                <div class="input-group">
                                    <select class="form-select">
                                        <option selected value="">All Venues</option>
                                        
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Search</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" placeholder="Search meetings...">
                                    <span class="input-group-text bg-white">
                                        <i class="bi bi-search"></i>
                                    </span>
                                </div>
                            </div>

                        </div>

                        <div class="row align-items-end">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Start Date</label>
                                <input type="date" class="form-control">
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">End Date</label>
                                <input type="date" class="form-control">
                            </div>

                            <div class="col-md-3">
                                <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                                    <i class="bi bi-funnel me-1"></i> Apply Filters
                                </button>
                            </div>

                            <div class="col-md-3">
                                <a href="#" class="btn btn-link text-decoration-none">
                                    <i class="bi bi-arrow-clockwise"></i> Clear
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0"><i class="bi bi-building me-2"></i>Scheduled Meetings</h5>

                        <a asp-controller="Meetings" asp-action="MeetingsAddEdit" class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                            <i class="bi bi-plus-lg"></i> Add Meeting
                        </a>
                    </div>

                    <!-- search -->

                    <form method="post" asp-action="MeetingsList" asp-controller="Meetings" class="mb-3">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label for="SearchText" class="form-label">Search Meetings</label>
                                <input type="text" name="SearchText" id="SearchText" class="form-control"
                                       placeholder="Enter Staff name" value="@ViewBag.SearchText" />
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-info">
                                    <i class="fas fa-search"></i> Search
                                </button>
                                <a asp-action="MeetingsList" asp-controller="Meetings" class="btn btn-secondary ms-2">
                                    <i class="fas fa-undo"></i> Reset
                                </a>
                            </div>
                        </div>
                    </form>

                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
                        <table class="table ">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Meeting Date</th>
                                    <th>Meeting Description</th>
                                    <th>Document Path</th>
                                    <th>Is Cancelled</th>
                                    <th>Cancellation Date Time</th>
                                    <th>Cancellation Reason</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var meetings in Model)
                                {

                                    <tr>
                                        <td>@meetings.MeetingID</td>
                                        <td>@meetings.MeetingDate</td>
                                        <td>@meetings.MeetingDescription</td>
                                        <td>@meetings.DocumentPath</td>
                                        <td>@meetings.IsCancelled</td>
                                        <td>@meetings.CancellationDateTime</td>
                                        <td>@meetings.CancellationReason</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-action="MeetingsAddEdit"
                                            asp-route-id="@meetings.MeetingID"
                                               title="Edit"
                                               style=" width:36px;
                                                       height:36px;
                                                       border:1.5px solid #0d6efd;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#0d6efd;
                                                       text-decoration:none;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="DeleteMeetings" asp-route-id="@meetings.MeetingID"
                                               title="Delete"
                                               style=" width:36px;
                                                       height:36px;
                                                       border:1.5px solid #dc3545;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#dc3545;
                                                       text-decoration:none">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>


                                }
                            </tbody>
                        </table>
                    }
                    <!-- End Table with stripped rows -->

                </div>
            </div>

        </div>
    </div>
</section>